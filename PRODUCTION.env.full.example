# Full production example for a public deployment with dashboard, OAuth, backups,
# alerts, and Steam-powered lobby creation enabled.

# Discord bot core
NODE_ENV=production
DISCORD_TOKEN=replace-with-your-discord-bot-token
CLIENT_ID=replace-with-your-discord-application-id
GUILD_ID=replace-with-your-primary-discord-guild-id

# Shared SQLite database
DATABASE_PATH=./src/data/dota-bot.sqlite

# STRATZ integration
STRATZ_API_KEY=replace-with-your-stratz-api-key
STRATZ_GRAPHQL_URL=https://api.stratz.com/graphql
STRATZ_TIMEOUT_MS=15000

# Matchmaking defaults
DEFAULT_ELO=1000
WIN_ELO=25
LOSS_ELO=25
QUEUE_SIZE=10
LOBBY_SIZE=10
TEAM_SIZE=5
MAX_PARTY_SIZE=5
READY_CHECK_SECONDS=90
READY_CHECK_POLL_MS=10000
CATEGORY_PREFIX=CB

# Public web dashboard
WEB_HOST=0.0.0.0
WEB_PORT=3000
WEB_DEFAULT_GUILD_ID=replace-with-your-primary-discord-guild-id
WEB_REFRESH_MS=15000
WEB_LIVE_HEARTBEAT_MS=25000
WEB_DB_WATCH_DEBOUNCE_MS=400
WEB_TITLE=Dota Matchmaking Pulse

# Web admin auth
WEB_ADMIN_TOKEN=replace-with-a-very-long-random-secret
WEB_ADMIN_ACTOR_ID=
WEB_ADMIN_ALLOWED_GUILD_IDS=replace-with-one-or-more-guild-ids

# Discord OAuth for public admin access
DISCORD_OAUTH_CLIENT_ID=replace-with-your-discord-application-id
DISCORD_OAUTH_CLIENT_SECRET=replace-with-your-discord-oauth-secret
DISCORD_OAUTH_REDIRECT_URI=https://your-domain.com/auth/discord/callback
DISCORD_OAUTH_SCOPES=identify guilds

# Internal bot control API
BOT_CONTROL_HOST=127.0.0.1
BOT_CONTROL_PORT=3001
BOT_CONTROL_TOKEN=replace-with-the-same-very-long-random-secret
BOT_CONTROL_URL=http://127.0.0.1:3001

# Reverse proxy / public domain
WEB_DOMAIN=your-domain.com

# Backups and alerts
BACKUP_DIRECTORY=./backups
BACKUP_RETENTION_COUNT=15
BACKUP_INTERVAL_MINUTES=360
BACKUP_ON_STARTUP=true
WEB_ALERT_CHANNEL_ID=replace-with-a-discord-channel-id-for-alerts

# Steam / Dota GC auto-lobby
STEAM_AUTO_LOBBY_ENABLED=true
STEAM_ACCOUNT_NAME=replace-with-your-steam-account-name
STEAM_PASSWORD=replace-with-your-steam-password
STEAM_SHARED_SECRET=replace-with-your-steam-shared-secret
STEAM_DATA_DIRECTORY=./src/data/steam
STEAM_LOBBY_REGION=europe
STEAM_LOBBY_GAME_MODE=captains_mode
STEAM_LOBBY_ALLOW_SPECTATING=false
STEAM_LOBBY_ALLCHAT=false
STEAM_LOBBY_PAUSE_SETTING=unlimited
STEAM_LOBBY_TV_DELAY=120
STEAM_LOBBY_DEBUG=false
